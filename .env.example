# LLM provider config.
# mock = local deterministic summaries (no external login)
# openai_compatible / hermes_agent = call a logged-in external/local agent API
HERMES_PROVIDER=mock
# For openai_compatible / hermes_agent:
# Hermes CLI proxy example: hermes proxy start --host 127.0.0.1 --port 8645
HERMES_BASE_URL=http://127.0.0.1:8645/v1
HERMES_MODEL=some-model-name
HERMES_API_KEY=optional
HERMES_WSTG_CHECKLIST_PATH=hermes_api/data/wstg_checklist.json
HERMES_SKILLS_DIR=hermes_api/skills
