# LLM provider config. For the basic version, the mock provider needs nothing.
HERMES_PROVIDER=mock
# For openai_compatible / ollama / lmstudio later:
HERMES_BASE_URL=http://localhost:11434/v1
HERMES_MODEL=some-model-name
HERMES_API_KEY=optional
HERMES_WSTG_CHECKLIST_PATH=/app/hermes_api/data/wstg_checklist.json
HERMES_SKILLS_DIR=/app/hermes_api/skills
